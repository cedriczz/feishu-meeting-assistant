# Optional path to the media-transcript skill script.
# If omitted, the app checks ./tools/media-transcript/scripts/run_media_transcript.py
# and ~/.codex/skills/media-transcript/scripts/run_media_transcript.py.
MEDIA_TRANSCRIPT_SCRIPT=

# balanced or best, depending on the installed media-transcript skill.
MEDIA_TRANSCRIPT_QUALITY=balanced

# Codex CLI model settings.
CODEX_MODEL=gpt-5.4
CODEX_FALLBACK_MODEL=

# Optional custom meeting-note format skill path.
# Defaults to ./skills/meeting-notes-format/SKILL.md.
MEETING_NOTES_SKILL_PATH=

# Optional Python executable override for Electron.
PYTHON_BIN=
