# Optional path to the media-transcript skill script.
# If omitted, the app checks ./tools/media-transcript/scripts/run_media_transcript.py
# and ~/.codex/skills/media-transcript/scripts/run_media_transcript.py.
MEDIA_TRANSCRIPT_SCRIPT=

# balanced or best, depending on the installed media-transcript skill.
MEDIA_TRANSCRIPT_QUALITY=balanced

# Generic Agent CLI settings.
# Supported providers:
# - auto: prefer AGENT_CLI_COMMAND, then claude, gemini, codex
# - claude: Claude Code CLI, command: claude
# - gemini: Gemini CLI, command: gemini
# - codex: OpenAI Codex CLI, command: codex
# - custom: any local CLI command that can read/write files in the job directory
AGENT_CLI_PROVIDER=auto

# Optional model override for the selected Agent CLI.
# Examples: claude-sonnet-4-5, gemini-2.5-pro, gpt-5.4
AGENT_CLI_MODEL=
AGENT_CLI_FALLBACK_MODEL=

# Custom Agent CLI mode.
# AGENT_CLI_COMMAND is the executable or command prefix.
# AGENT_CLI_ARGS can be a shell-like string or JSON string array.
# Supported placeholders: {job_dir}, {prompt_file}, {model}, {output_message}
# If AGENT_CLI_STDIN=true, the full prompt is passed on stdin.
AGENT_CLI_COMMAND=
AGENT_CLI_ARGS=
AGENT_CLI_STDIN=false

# Legacy Codex settings. Used only when AGENT_CLI_PROVIDER=codex
# or auto selects codex.
CODEX_MODEL=gpt-5.4
CODEX_FALLBACK_MODEL=

# Optional custom meeting-note format skill path.
# Defaults to ./skills/meeting-notes-format/SKILL.md.
MEETING_NOTES_SKILL_PATH=

# Optional Python executable override for Electron.
PYTHON_BIN=
